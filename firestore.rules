rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read, create, update, delete: if true;
    }

    match /settings/{document} {
      allow read, write: if true;
    }

    match /requests/{requestId} {
      allow read, create, update, delete: if true;
    }
  }
}
